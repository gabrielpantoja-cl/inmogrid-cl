# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
playwright-report/
playwright/.auth/
test-results/
.env.test.local

# Playwright MCP (screenshots, console logs)
.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Screenshots
*.png
*.jpeg
!public/**/*.png
!public/**/*.jpeg
!docs/**/*.png
# Next.js file-based metadata icons (favicon, apple-icon, opengraph-image, etc.)
!src/app/**/*.png
!src/app/**/*.jpeg

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# package-lock.json  # COMENTADO: necesario para GitHub Actions deployment
yarn.lock         

# local env files
.env.development  
.env.production   
.env*.local       
.env              

# vercel
.vercel           

# typescript
*.tsbuildinfo     
next-env.d.ts     


# IDE/tools
.codegpt

# draw.io files
*.drawio          
*.drawio.bkp      

# Database backups & one-off migration scripts
# NUNCA commitear pg_dump ni scripts con data real / UUIDs de usuarios,
# este repo es opensource.
*.dump
backup_produccion.sql
scripts/migrations/
!scripts/sql/*.sql

# MCP configuration
.mcp.json
.env.backup.*

# Claude Code — personal/local files (gitignored)
CLAUDE.local.md
.claude/settings.local.json
# Note: .claude/agents/ se commitea — son prompts de comportamiento
# del proyecto, no contienen secretos. Cualquier agent que requiera
# datos sensibles debe leerlos desde infra/privado/, no inlinearlos.

# Local-only scripts/utilities
src/_private/

# Archive (large/legacy files)
/archive/

# Installers and binaries
*.deb
.vercel

# Root-level zips (reference material, design mocks, etc.)
/*.zip
respuestas.txt
