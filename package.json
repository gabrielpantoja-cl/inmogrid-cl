{
  "name": "inmogrid-cl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "seed": "node prisma/seed.mjs",
    "build": "npx prisma generate && next build",
    "dev": "next dev --turbo",
    "dev:tunnel": "ssh -N -L 5432:localhost:5432 <SSH_USER>@<VPS_HOST>",
    "dev:full": "bash scripts/dev-with-tunnel.sh",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "test:api": "jest __tests__/api --testTimeout=10000",
    "test:public-api": "jest __tests__/api/public --testTimeout=10000",
    "test-public-api": "node scripts/test-public-api.js",
    "api:health": "curl http://localhost:3000/api/public/health",
    "api:health-stats": "curl \"http://localhost:3000/api/public/health?stats=true\"",
    "api:config": "curl http://localhost:3000/api/public/map-config",
    "api:test-data": "curl \"http://localhost:3000/api/public/map-data?limit=5\"",
    "api:docs": "curl http://localhost:3000/api/public/docs",
    "api:test": "bash scripts/test-api-public.sh",
    "api:test:windows": "powershell -ExecutionPolicy Bypass -File scripts/test-api-public.ps1",
    "api:test:simple": "curl -s http://localhost:3000/api/public/map-data?limit=1 | jq",
    "api:test:filters": "curl -s \"http://localhost:3000/api/public/map-data?comuna=santiago&anio=2024&limit=3\" | jq",
    "api:validate": "curl -s http://localhost:3000/api/public/map-config | jq .success",
    "dev:api-monitor": "watch -n 5 'curl -s http://localhost:3000/api/public/health | jq'",
    "clean": "rimraf .next",
    "clean:cache": "rimraf .next && rimraf node_modules/.cache",
    "clean:full": "rimraf .next && rimraf node_modules && rimraf package-lock.json",
    "prisma:generate": "dotenv -e .env.local -- npx prisma generate",
    "prisma:push": "dotenv -e .env.local -- npx prisma db push",
    "prisma:reset": "dotenv -e .env.local -- npx prisma generate && dotenv -e .env.local -- npx prisma db push",
    "prisma:studio": "dotenv -e .env.local -- npx prisma studio",
    "prisma:studio:prod": "dotenv -e .env.local -- npx prisma studio",
    "optimize:images": "node scripts/optimize-images.js",
    "check:images": "node scripts/check-images.js",
    "api:v1:health": "curl http://localhost:3000/api/v1/health",
    "api:v1:health-stats": "curl \"http://localhost:3000/api/v1/health?stats=true\"",
    "api:v1:test": "curl \"http://localhost:3000/api/v1/map-data?limit=5\"",
    "api:v1:comunas": "curl http://localhost:3000/api/v1/map-data/comunas",
    "api:v1:config": "curl http://localhost:3000/api/v1/map-config",
    "api:v1:docs": "curl http://localhost:3000/api/v1/docs",
    "deploy:check": "npm run build && npm run test:public-api && echo '✅ Build + tests passed — ready to deploy'",
    "docs:api": "echo '📖 API Docs: http://localhost:3000/api/v1/docs'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:vps": "PLAYWRIGHT_BASE_URL=https://inmogrid.cl playwright test",
    "test:e2e:local": "PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test",
    "playwright:install": "npx playwright install --with-deps"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
