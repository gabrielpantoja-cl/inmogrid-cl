# =========================================
# ⚠️  SOLO TEMPLATE — NO PEGAR VALORES REALES
# =========================================
# Este archivo es un TEMPLATE público que viaja en el repo opensource.
# Nunca escribas aquí secretos reales (OAuth client secrets, passwords
# de DB, API keys, tokens). Usá `.env.local` para los valores reales —
# ese archivo está en `.gitignore` y nunca se commitea.
#
# Si encontrás un valor real acá, es un bug — reportalo o rotalo.

# =========================================
# 🗄️ SUPABASE POSTGRESQL (Prisma ORM)
# =========================================
# Obtener desde: Supabase → Settings → Database → Connection String
# Usar el pooler (puerto 6543) para DATABASE_URL (PgBouncer)
# Usar la conexión directa (puerto 5432) para DIRECT_URL (migrations)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# =========================================
# 🗄️ NEON DATABASE (referenciales — read-only)
# =========================================
# Base de datos de referenciales inmobiliarios verificados.
# Solo lectura desde inmogrid.cl — escritura via pipeline de contribuciones.
NEON_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/referenciales?sslmode=require"

# =========================================
# 🔐 SUPABASE AUTH
# =========================================
# Obtener desde: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# =========================================
# 🔑 GOOGLE OAUTH 2.0
# =========================================
# Configurar en: https://console.cloud.google.com/apis/credentials
# Crea un proyecto GCP propio y un OAuth 2.0 Client ID de tipo "Web
# application", después pegá los valores acá.
#
# URLs de callback autorizadas (AMBAS configuradas en Google Cloud Console):
# - Desarrollo: http://localhost:3000/api/auth/callback/google
# - Producción: https://inmogrid.cl/api/auth/callback/google
#
# Orígenes JavaScript autorizados:
# - Desarrollo: http://localhost:3000
# - Producción: https://inmogrid.cl
GOOGLE_CLIENT_ID="REPLACE_ME.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-REPLACE_ME_IN_PRODUCTION"

# =========================================
# 🗺️ GOOGLE MAPS API (GEOCODING)
# =========================================
# Para geocodificación de direcciones
# Configurar en: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# =========================================
# 🤖 GEMINI AI (Sofia RAG chatbot)
# =========================================
# Free API key from: https://aistudio.google.com/apikey
# Used for: Gemini 2.5 Flash (chat) + text-embedding-004 (embeddings)
GEMINI_API_KEY="AIza..."

# =========================================
# 🚦 RATE LIMITING (Upstash Redis — OPTIONAL)
# =========================================
# Sin estas variables, el rate limiting se desactiva (fail open).
# Crear cuenta gratis en: https://upstash.com
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# =========================================
# 🔗 N8N WEBHOOKS (OPCIONAL)
# =========================================
# Para importación masiva de datos desde N8N
N8N_WEBHOOK_URL="https://n8n.example.com/webhook/bulk-import"
N8N_WEBHOOK_SECRET="your_n8n_webhook_secret"

# Login notification webhook — fires once per OAuth exchange from
# src/app/auth/callback/route.ts. Leave unset to disable notifications.
N8N_LOGIN_WEBHOOK_URL="https://n8n.example.com/webhook/inmogrid-login"

# =========================================
# 🔑 REVALIDATION SECRET
# =========================================
# Used by /api/revalidate to protect on-demand ISR revalidation
REVALIDATE_SECRET="your_revalidate_secret_here"

# =========================================
# 📦 REPOSITORIO GITHUB
# =========================================
NEXT_PUBLIC_GITHUB_REPO_OWNER="TheCuriousSloth"
NEXT_PUBLIC_GITHUB_REPO_NAME="inmogrid.cl"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/TheCuriousSloth/inmogrid.cl"

# Token de GitHub (opcional, para mayor rate limit en API)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# 🌐 BASE URL
# =========================================
# Desarrollo:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Producción:
NEXT_PUBLIC_BASE_URL="https://inmogrid.cl"

# =========================================
# 📧 EMAIL (OPCIONAL — Resend)
# =========================================
# Para notificaciones de cuenta
# RESEND_API_KEY="re_..."

# =========================================
# ☁️ CLOUDFLARE R2 (imágenes del blog)
# =========================================
# Docs: https://developers.cloudflare.com/r2/api/s3/
# Crear credenciales en: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Bucket: inmogrid-blog | Dominio: images.inmogrid.cl
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="inmogrid-blog"
# Dev: https://<bucket>.<accountid>.r2.dev  /  Prod: https://images.inmogrid.cl
NEXT_PUBLIC_R2_IMAGES_URL="https://images.inmogrid.cl"

# =========================================
# 🤖 OPENAI (OPCIONAL)
# =========================================
# OPENAI_API_KEY="sk-..."
