# 🔐 Playwright E2E Testing - Google OAuth Credentials
#
# IMPORTANTE: Este archivo es un EJEMPLO.
# Crea un archivo .env.test.local con tus credenciales reales.
#
# ⚠️  NUNCA commitees .env.test.local al repositorio
# ⚠️  Usa una cuenta de Google dedicada para testing
# ⚠️  NO uses tu cuenta personal de Google

# Email de Google para testing E2E
GOOGLE_TEST_EMAIL=test-inmogrid@gmail.com

# Contraseña de Google para testing E2E
GOOGLE_TEST_PASSWORD=your-secure-test-password

# URL base para tests (producción o staging)
PLAYWRIGHT_BASE_URL=https://inmogrid.cl

# Para tests en localhost (desarrollo)
# PLAYWRIGHT_BASE_URL=http://localhost:3000