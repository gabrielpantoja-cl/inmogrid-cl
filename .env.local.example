# =========================================
# ⚠️  SOLO TEMPLATE — NO PEGAR VALORES REALES
# =========================================
# Este archivo es un TEMPLATE público que viaja en el repo opensource.
# Nunca escribas aquí secretos reales (OAuth client secrets, NextAuth
# secrets, API keys, tokens). Usá `.env.local` para los valores reales —
# ese archivo está en `.gitignore` y nunca se commitea.
#
# Si encontrás un valor real acá, es un bug — reportalo o rotalo. Ver
# `infra/privado/inmogrid.cl/secret-exposure-incident-2026-04-11.md`.

# =========================================
# 🔧 EJEMPLO DE CONFIGURACIÓN LOCAL (.env.local)
# =========================================
# Copia este archivo a .env.local y ajusta los valores

# =========================================
# 🗄️ BASE DE DATOS LOCAL (Docker)
# =========================================
# PostgreSQL local con PostGIS para desarrollo
# Levantar con: docker compose -f docker/docker-compose.local.yml up -d

POSTGRES_PRISMA_URL="postgresql://inmogrid_user:inmogrid_local_password@localhost:5432/inmogrid_dev?schema=public"

# =========================================
# 🔐 NEXTAUTH.JS - AUTENTICACIÓN LOCAL
# =========================================
# NOTA: inmogrid.cl ya no usa NextAuth — migró a Supabase Auth en
# 2026-04-11 (ver docs/authentication.md). Estas variables quedan por
# si algún proyecto legacy en el monorepo aún las necesita.
#
# Genera un secret nuevo con: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_DEBUG="true"

# =========================================
# 🔑 GOOGLE OAUTH 2.0
# =========================================
# Configurar en: https://console.cloud.google.com/apis/credentials
# Asegúrate de agregar http://localhost:3000/api/auth/callback/google
# en Google Cloud Console → Authorized redirect URIs

GOOGLE_CLIENT_ID="REPLACE_ME.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-REPLACE_ME_IN_PRODUCTION"

# =========================================
# 🗺️ GOOGLE MAPS API (GEOCODING)
# =========================================
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# =========================================
# 🔗 N8N WEBHOOKS (OPCIONAL)
# =========================================
N8N_WEBHOOK_URL="https://n8n.example.com/webhook/"
N8N_WEBHOOK_SECRET="your_n8n_webhook_secret"

# Login notification webhook — fires once per OAuth exchange from
# src/app/auth/callback/route.ts. Delivers a Resend email via the
# INMOGRID-LOGIN-NOTIFY workflow. Leave unset to disable notifications.
N8N_LOGIN_WEBHOOK_URL="https://n8n.example.com/webhook/inmogrid-login"

# =========================================
# ☁️ CLOUDFLARE API (OPCIONAL)
# =========================================
CLOUDFLARE_API_TOKEN="your_cloudflare_token"
CLOUDFLARE_ZONE_ID="your_zone_id"

# =========================================
# ☁️ CLOUDFLARE R2 (imágenes del blog)
# =========================================
# Bucket: inmogrid-blog | Dominio prod: images.inmogrid.cl
# Dev: usar la URL r2.dev del bucket (sin custom domain)
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="inmogrid-blog"
NEXT_PUBLIC_R2_IMAGES_URL="https://inmogrid-blog.<accountid>.r2.dev"

# =========================================
# 📦 REPOSITORIO GITHUB
# =========================================
NEXT_PUBLIC_GITHUB_REPO_OWNER="gabrielpantoja-cl"
NEXT_PUBLIC_GITHUB_REPO_NAME="inmogrid"
NEXT_PUBLIC_GITHUB_REPO_URL="https://github.com/gabrielpantoja-cl/inmogrid"